PORT=4000
JWT_SECRET=change-this-secret

# 钉钉表格配置。留空时服务端会使用 mock 数据，方便本地开发预览。
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_WORKBOOK_ID=
DINGTALK_OPERATOR_ID=

# 可选：钉钉开放 API 地址，默认 https://api.dingtalk.com
DINGTALK_API_BASE_URL=https://api.dingtalk.com
DINGTALK_CACHE_TTL_SECONDS=180
DINGTALK_CACHE_STALE_SECONDS=86400
DINGTALK_API_MONTHLY_WARN_LIMIT=5000
LOCAL_LOGIN_ENABLED=false
DEFAULT_USER_PASSWORD=123456
DINGTALK_LOCAL_FIRST=true
DINGTALK_SYNC_ENABLED=true
DINGTALK_SYNC_TIME=02:00
DINGTALK_SYNC_STARTUP_ENABLED=true
DINGTALK_SYNC_STARTUP_DELAY_MS=15000
