{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p tsconfig.json",
    "check:dingtalk": "ts-node-dev --transpile-only --exit-child src/scripts/checkDingTalk.ts",
    "get:operator": "ts-node-dev --transpile-only --exit-child src/scripts/getOperatorIdByMobile.ts",
    "inspect:range": "ts-node-dev --transpile-only --exit-child src/scripts/inspectRange.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "axios": "^1.6.8",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "sql.js": "^1.10.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^16.18.101",
    "@types/sql.js": "^1.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "5.2.2"
  }
}
